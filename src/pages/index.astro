---
import { getCollection, getEntry } from 'astro:content';
import AcquisitionCTA from '../components/AcquisitionCTA.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import { SITE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteEntry = await getEntry('site', 'default');
if (!siteEntry) throw new Error('Site config missing');
const siteConfig = siteEntry.data;

const reasons = (await getCollection('reasons')).sort(
  (a, b) => a.data.number - b.data.number,
);
---

<BaseLayout>
  <Nav />

  <main>
    <!-- HERO -->
    <header class="hero-bg min-h-[100dvh] flex items-center pt-16 relative">
      <div class="max-w-screen-xl mx-auto px-6 pt-12 pb-20">
        <div class="max-w-5xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-8">
            <div class="flex items-center gap-x-1.5">
              <div class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></div>
              <span class="text-cyan-400 text-xs font-semibold tracking-[1.5px] uppercase">Premium .com • Available Now</span>
            </div>
          </div>

          <div class="max-w-4xl">
            <h1 class="font-display text-[4rem] md:text-[5.5rem] leading-[0.95] tracking-[-4px] font-extrabold mb-2">
              <span class="quantum-gradient">quantumnestcast</span><br />
              <span class="text-5xl md:text-6xl text-white tracking-tight">.com</span>
            </h1>

            <p class="text-3xl md:text-4xl text-white font-display font-semibold tracking-tight mt-2 mb-3">
              The Nest Where the Quantum Future Takes Flight
            </p>

            <p class="max-w-2xl text-xl md:text-2xl text-zinc-400 font-light tracking-tight leading-tight mb-10">
              Own the premier digital asset for a landmark educational platform, podcast series, or knowledge hub at the heart of the Second Quantum Revolution.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <AcquisitionCTA label="Inquire for Acquisition" variant="white" icon="fa-arrow-right-long" />
            <a href="#moment" class="px-8 py-4 border border-white/30 hover:bg-white/5 active:bg-white/10 transition-all font-semibold text-lg rounded-3xl flex items-center justify-center gap-x-2 w-full sm:w-auto text-white no-underline">
              <span>Explore the Opportunity</span>
            </a>
          </div>

          <div class="mt-10 flex items-center gap-x-8 text-sm">
            <div class="flex items-center gap-x-2 text-zinc-400">
              <i class="fa-solid fa-check text-emerald-400"></i>
              <span>Premium Strategic Asset</span>
            </div>
            <div class="flex items-center gap-x-2 text-zinc-400">
              <i class="fa-solid fa-check text-emerald-400"></i>
              <span>Instant Category Authority</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 hidden lg:block">
        <div class="flex flex-col items-center text-xs tracking-[2px] text-zinc-500">
          <span>SCROLL TO EXPLORE</span>
          <i class="fa-solid fa-chevron-down mt-1.5 animate-bounce"></i>
        </div>
      </div>
    </header>

    <!-- TRUST BAR -->
    <div class="border-b border-zinc-800 bg-zinc-900/60 py-5">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-3 text-sm">
          {
            siteConfig.trustPoints.map((point) => (
              <div class="flex items-center gap-x-2 text-zinc-400">
                <i class="fa-solid fa-circle-check text-cyan-400"></i>
                <span class="font-medium">{point}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- THE MOMENT — Second Quantum Revolution -->
    <section id="moment" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
          <div class="inline-block px-4 py-1 rounded-3xl bg-cyan-400/10 text-cyan-400 text-xs font-bold tracking-[2px] mb-4">THE MOMENT</div>
          <h2 class="section-header tracking-[-2.5px]">We are living through the<br /><span class="quantum-gradient">Second Quantum Revolution</span></h2>
        </div>

        <div class="prose prose-invert prose-lg max-w-none text-zinc-300 space-y-5">
          <p class="text-xl leading-relaxed">The first quantum revolution gave us transistors, lasers, and MRI machines — technologies that harnessed quantum effects without directly controlling individual quantum states. The second revolution is different. It is about <strong class="text-white">actively engineering</strong> superposition, entanglement, and quantum coherence at the level of single particles and systems.</p>

          <p>This is the era of quantum key distribution and secure quantum networks; quantum sensors achieving unprecedented precision in metrology, navigation, and medical imaging; quantum materials and out-of-equilibrium dynamics explored through cold atoms and advanced simulations; and quantum information science — algorithms, error correction, simulation of complex systems, and the conceptual foundations that will redefine computing.</p>

          <p>Progress now depends on bridging deep theoretical understanding with the formidable engineering challenges of building stable, scalable quantum devices. The winners will be those who can <strong class="text-white">educate, translate, and lead</strong> this transition.</p>

          <p class="text-lg font-semibold text-cyan-300 border-l-4 border-cyan-400 pl-5 py-1">quantumnestcast.com is positioned to become the trusted home for exactly that mission.</p>
        </div>
      </div>
    </section>

    <!-- THE BRAND -->
    <section id="brand" class="bg-zinc-900 border-y border-zinc-800 py-20">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <div class="inline-block px-4 py-1 rounded-3xl bg-purple-400/10 text-purple-400 text-xs font-bold tracking-[2px] mb-4">THE BRAND</div>
            <h2 class="section-header tracking-[-2.5px]">Quantum Nestcast —<br /><span class="quantum-gradient">A Name That Works on Multiple Levels</span></h2>
          </div>

          <div class="grid md:grid-cols-2 gap-10 items-start">
            <div>
              <div class="prose prose-invert prose-lg max-w-none text-zinc-300 space-y-4">
                <p class="leading-relaxed"><strong class="text-white">"Nestcast"</strong> is a powerful, ownable compound word that communicates depth and authority instantly.</p>

                <div class="mt-4 space-y-4">
                  <div class="flex items-start gap-x-3">
                    <div class="w-8 h-8 rounded-xl quantum-glow flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span class="text-zinc-950 font-bold">N</span>
                    </div>
                    <div>
                      <strong class="text-white">Nest</strong> — A protected, curated space for incubation and growth. A sanctuary where complex ideas are nurtured into clarity. It suggests community, depth, and a gathering place for serious learners and experts.
                    </div>
                  </div>
                  <div class="flex items-start gap-x-3">
                    <div class="w-8 h-8 rounded-xl quantum-glow flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span class="text-zinc-950 font-bold">C</span>
                    </div>
                    <div>
                      <strong class="text-white">Cast</strong> — Evokes broadcasting, masterclasses, podcasting, and "casting light" on difficult subjects. It signals premium, in-depth content rather than superficial coverage.
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-zinc-950 border border-zinc-800 rounded-3xl p-10">
              <div class="text-sm uppercase tracking-[2px] text-zinc-500 mb-4">BRAND ARCHITECTURE</div>
              <div class="space-y-6 text-lg">
                <div>
                  <div class="font-mono text-xs text-cyan-400 tracking-widest mb-1">THE COMPOUND WORD</div>
                  <div class="text-3xl font-semibold tracking-tight">Nest + Cast = Nestcast</div>
                </div>
                <div class="pt-4 border-t border-zinc-700">
                  <div class="text-zinc-400">Short enough to be <span class="text-white font-medium">memorable</span>, distinctive enough to <span class="text-white font-medium">own</span>, and descriptive enough to carry instant <span class="text-white font-medium">category relevance</span>.</div>
                </div>
              </div>
            </div>
          </div>

          <!-- What the Platform Can Deliver -->
          <div class="mt-16 pt-12 border-t border-zinc-800">
            <h3 class="font-display text-3xl tracking-tight mb-8 text-center">What the Platform Can Deliver</h3>
            <div class="grid md:grid-cols-3 gap-6">
              <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-3xl p-8">
                <div class="w-11 h-11 rounded-2xl quantum-glow flex items-center justify-center mb-5">
                  <i class="fa-solid fa-flask text-zinc-950 text-lg"></i>
                </div>
                <h4 class="font-semibold text-lg tracking-tight mb-3">Theoretical Depth</h4>
                <p class="text-zinc-400 leading-relaxed text-sm">Rigorous explorations of quantum optics & communication (QKD, quantum networking), quantum sensing & metrology, quantum materials, and quantum information.</p>
              </div>
              <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-3xl p-8">
                <div class="w-11 h-11 rounded-2xl quantum-glow flex items-center justify-center mb-5">
                  <i class="fa-solid fa-microchip text-zinc-950 text-lg"></i>
                </div>
                <h4 class="font-semibold text-lg tracking-tight mb-3">Industry & Engineering Reality</h4>
                <p class="text-zinc-400 leading-relaxed text-sm">Regular insights from researchers, hardware builders, startup founders, and corporate leaders confronting physics-to-device translation challenges.</p>
              </div>
              <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-3xl p-8">
                <div class="w-11 h-11 rounded-2xl quantum-glow flex items-center justify-center mb-5">
                  <i class="fa-solid fa-podcast text-zinc-950 text-lg"></i>
                </div>
                <h4 class="font-semibold text-lg tracking-tight mb-3">Formats That Scale</h4>
                <p class="text-zinc-400 leading-relaxed text-sm">Long-form podcast episodes, lecture series, masterclasses, expert interviews, and curated learning paths for graduate students, engineers, executives, and investors.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY PREMIUM -->
    <section id="why-premium" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <div class="inline-block px-4 py-1 rounded-3xl bg-cyan-400/10 text-cyan-400 text-xs font-bold tracking-[2px] mb-4">PREMIUM ASSET</div>
        <h2 class="section-header tracking-[-2.5px]">Why quantumnestcast.com<br />justifies a <span class="quantum-gradient">premium acquisition price</span></h2>
        <p class="mt-5 text-xl text-zinc-400">In frontier technology verticals, the right domain name is a strategic asset, not a commodity.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {
          reasons.map((reason) => (
            <div class="reason-card bg-zinc-900 border border-zinc-800 rounded-3xl p-8 flex flex-col">
              <div class="w-12 h-12 flex items-center justify-center rounded-2xl quantum-glow bg-opacity-10 mb-6">
                <span class="text-2xl font-extrabold font-display text-zinc-950">{String(reason.data.number).padStart(2, '0')}</span>
              </div>
              <h3 class="font-semibold text-xl tracking-tight mb-3">{reason.data.title}</h3>
              <p class="text-zinc-400 leading-relaxed flex-grow">{reason.data.description}</p>
            </div>
          ))
        }
      </div>

      <div class="max-w-3xl mx-auto mt-12 text-center text-sm text-zinc-500 border-t border-zinc-800 pt-8">
        The quantum technology sector is moving from research curiosity to commercial reality at extraordinary speed. Organizations that establish clear thought leadership now will define the conversation for the next two decades. The right domain is the foundation of that leadership.
      </div>
    </section>

    <!-- MARKET OPPORTUNITY -->
    <section class="bg-zinc-900 border-y border-zinc-800 py-20">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <div class="inline-block px-4 py-1 rounded-3xl bg-emerald-400/10 text-emerald-400 text-xs font-bold tracking-[2px] mb-4">THE OPPORTUNITY</div>
            <h2 class="section-header tracking-[-2.5px]">A market racing<br />toward <span class="quantum-gradient">commercial reality</span></h2>
          </div>

          <div class="prose prose-invert prose-lg max-w-none text-zinc-300 space-y-5">
            <p class="text-xl leading-relaxed">The quantum computing market alone is projected to grow from roughly $1.5 billion in 2025 to $18+ billion by the early 2030s, with broader quantum technologies — sensing, communication, materials — adding substantial additional value. McKinsey and others project trillions in potential economic impact by 2035 as these technologies move into pharmaceuticals, finance, logistics, defense, and materials science.</p>

            <p>The bottleneck will not only be hardware — it will be <strong class="text-white">human capital and shared understanding</strong>. The organizations and platforms that can clearly explain both the physics and the engineering realities will hold disproportionate influence.</p>
          </div>

          <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">$1.5B</div>
              <div class="text-sm text-zinc-400 mt-1">Market in 2025</div>
            </div>
            <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">$18B+</div>
              <div class="text-sm text-zinc-400 mt-1">By Early 2030s</div>
            </div>
            <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">Trillions</div>
              <div class="text-sm text-zinc-400 mt-1">Impact by 2035</div>
            </div>
            <div class="reason-card bg-zinc-950 border border-zinc-800 rounded-2xl p-6 text-center">
              <div class="text-4xl font-semibold text-white tracking-tighter">&infin;</div>
              <div class="text-sm text-zinc-400 mt-1">Applications</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- IDEAL BUYERS -->
    <section id="buyers" class="max-w-screen-xl mx-auto px-6 pt-20 pb-16">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <div class="inline-block px-4 py-1 rounded-3xl bg-purple-400/10 text-purple-400 text-xs font-bold tracking-[2px] mb-4">IDEAL BUYERS &amp; USE CASES</div>
        <h2 class="section-header tracking-[-2.5px]">Built for those ready to<br />own the <span class="quantum-gradient">quantum narrative</span></h2>
        <p class="mt-3 text-xl text-zinc-400">This domain is a strategic foundation for serious players in the quantum ecosystem.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {
          siteConfig.useCaseCategories.map((useCase, i) => (
            <div class="use-case-card bg-zinc-900 border border-zinc-800 hover:border-cyan-400/60 rounded-3xl p-8 flex flex-col">
              <div class="flex items-center gap-x-4 mb-5">
                <div class="w-11 h-11 rounded-2xl quantum-glow flex items-center justify-center flex-shrink-0">
                  <span class="text-zinc-950 font-bold text-lg">{i + 1}</span>
                </div>
                <div>
                  <div class="font-semibold text-lg tracking-tight">{useCase.title}</div>
                </div>
              </div>
              <p class="text-zinc-400 flex-grow text-[15px] leading-relaxed">{useCase.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- THIS IS MORE THAN A DOMAIN -->
    <section class="max-w-screen-xl mx-auto px-6 py-20">
      <div class="max-w-4xl mx-auto text-center">
        <div class="mx-auto mb-8 inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/5 border border-white/10">
          <i class="fa-solid fa-atom text-4xl quantum-gradient"></i>
        </div>

        <h2 class="font-display text-5xl md:text-6xl tracking-[-2.5px] leading-none font-extrabold mb-6">
          This Is More Than a Domain —<br />
          <span class="quantum-gradient">It's the Foundation of Thought Leadership</span>
        </h2>

        <div class="prose prose-invert prose-lg max-w-2xl mx-auto text-zinc-300 space-y-4">
          <p>
            In a frontier technology landscape crowded with noise, <strong class="text-white">quantumnestcast.com</strong> stands apart. It is the name that positions its owner as the definitive voice — serious, credible, and built for the long arc of quantum progress.
          </p>
          <p>
            Whether you are a quantum company seeking to own the education and narrative layer, an EdTech entrepreneur building the "go-to" destination for quantum literacy, a university or research consortium launching flagship programs, or an investor creating a high-signal platform — this domain is ready to serve as the cornerstone.
          </p>
        </div>
      </div>
    </section>

    <!-- ACQUISITION SECTION -->
    <section class="bg-zinc-900 border-y border-zinc-800 py-16">
      <div class="max-w-screen-xl mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <div class="inline-block px-5 py-1.5 rounded-3xl quantum-glow text-zinc-950 text-xs font-extrabold tracking-[1.5px] mb-4">ACQUISITION</div>
            <h2 class="section-header tracking-[-2px]">Ready to own the nest<br />where quantum takes flight?</h2>
          </div>

          <div class="bg-zinc-950 border border-zinc-700 rounded-3xl p-10 md:p-14">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-y-8">
              <div>
                <div class="text-sm uppercase tracking-[3px] text-cyan-400 font-bold mb-2">Premium Strategic Asset</div>
                <div class="flex items-baseline gap-x-2">
                  <span class="text-5xl font-extrabold tabular-nums tracking-[-2px]">Price on Request</span>
                </div>
                <div class="text-sm text-zinc-400 mt-1">One-time acquisition • Full ownership transfer</div>

                <div class="mt-6 text-sm max-w-xs">
                  <div class="flex items-center gap-x-2 text-emerald-400">
                    <i class="fa-solid fa-check"></i>
                    <span class="font-medium">Premium pricing reflects scarcity, brand strength, and alignment with one of the most consequential technology shifts of the 21st century</span>
                  </div>
                </div>
              </div>

              <div class="lg:text-right">
                <AcquisitionCTA label="Submit Acquisition Inquiry" variant="accent" icon="fa-arrow-right-long" />
                <div class="mt-4 text-xs text-zinc-400">Serious buyers only • Escrow protected</div>
              </div>
            </div>

            <div class="mt-10 pt-8 border-t border-zinc-700 grid grid-cols-1 sm:grid-cols-3 gap-y-6 text-sm">
              <div>
                <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-handshake text-cyan-400"></i> <span>Transaction</span></div>
                <div class="text-zinc-400">Handled via Escrow.com or your preferred platform. Full domain push + DNS control transfer.</div>
              </div>
              <div>
                <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-file-contract text-cyan-400"></i> <span>Confidential</span></div>
                <div class="text-zinc-400">All inquiries are handled confidentially. Pricing reflects brand strength, keyword alignment, category positioning, and long-term appreciation potential.</div>
              </div>
              <div>
                <div class="font-semibold mb-1 flex items-center gap-x-2"><i class="fa-solid fa-globe text-cyan-400"></i> <span>Why Now?</span></div>
                <div class="text-zinc-400">The organizations that establish clear thought leadership in the quantum revolution now will define the conversation for the next two decades.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <div class="bg-gradient-to-b from-zinc-900 to-zinc-950 py-16">
      <div class="max-w-screen-xl mx-auto px-6 text-center">
        <div class="max-w-lg mx-auto">
          <h3 class="font-display text-5xl tracking-[-2px] font-extrabold mb-4">The quantum future<br />has a home.</h3>
          <p class="text-xl text-zinc-300 mb-8">Claim the premium domain built to lead the Second Quantum Revolution.</p>

          <AcquisitionCTA label="Inquire to Acquire" variant="accent" />
        </div>
      </div>
    </div>
  </main>

  <Footer disclaimer={siteConfig.disclaimer} />
</BaseLayout>
